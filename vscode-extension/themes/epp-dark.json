{
  "name": "E++ Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#d4d4d4"
  },
  "tokenColors": [
    {
      "scope": "comment.line.number-sign.epp",
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword.control.if.epp",
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.control.block.if.epp",
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.control.repeat.epp",
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.control.times.epp",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "keyword.declaration.epp",
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.operator.epp",
      "settings": {
        "foreground": "#d4d4d4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.command.output.epp",
      "settings": {
        "foreground": "#dcdcaa",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.command.input.epp",
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.command.assignment.epp",
      "settings": {
        "foreground": "#c586c0"
      }
    },
    {
      "scope": "keyword.command.gui.epp",
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.command.game.epp",
      "settings": {
        "foreground": "#c586c0",
        "fontStyle": "bold italic"
      }
    },
    {
      "scope": "string.quoted.double.epp",
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "scope": "constant.numeric.integer.epp",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "constant.numeric.float.epp",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": "keyword.operator.arithmetic.epp",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "scope": "variable.other.epp",
      "settings": {
        "foreground": "#9cdcfe"
      }
    }
  ]
}