{
  "scopeName": "source.epp",
  "name": "E++",
  "patterns": [
    {
      "name": "comment.line.number-sign.epp",
      "match": "#.*$"
    },
    {
      "name": "keyword.control.if.epp",
      "match": "\\bif\\b"
    },
    {
      "name": "keyword.control.block.if.epp",
      "match": "\\bend\\s+if\\b"
    },
    {
      "name": "keyword.control.repeat.epp",
      "match": "\\b(repeat|end\\s+repeat)\\b"
    },
    {
      "name": "keyword.declaration.epp",
      "match": "\\blet\\b"
    },
    {
      "name": "keyword.operator.epp",
      "match": "\\b(is|is\\s+not|greater\\s+than|less\\s+than)\\b"
    },
    {
      "name": "keyword.command.output.epp",
      "match": "\\b(say|print)\\b"
    },
    {
      "name": "keyword.command.input.epp",
      "match": "\\b(ask|as)\\b"
    },
    {
      "name": "keyword.command.assignment.epp",
      "match": "\\bbe\\b"
    },
    {
      "name": "keyword.command.gui.epp",
      "match": "\\b(show\\s+window|add\\s+button|add\\s+label|add\\s+text|set\\s+title|run\\s+window)\\b"
    },
    {
      "name": "keyword.command.game.epp",
      "match": "\\b(game\\s+window|create\\s+object|move|set\\s+color|when\\s+key|remove|game\\s+loop)\\b"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.epp",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.epp" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.epp" }
      }
    },
    {
      "name": "constant.numeric.integer.epp",
      "match": "\\b[0-9]+\\b"
    },
    {
      "name": "constant.numeric.float.epp",
      "match": "\\b[0-9]+\\.[0-9]+\\b"
    },
    {
      "name": "keyword.operator.arithmetic.epp",
      "match": "[+\\-*/]"
    },
    {
      "name": "variable.other.epp",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ],
  "fileTypes": ["epp"]
}